---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="footer-copy">
      &copy; {year} USMLE Prep Guide. For informational purposes only. Not affiliated with the NBME or USMLE program.
    </p>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/disclaimer">Affiliate Disclaimer</a>
      <a href="/rss.xml">RSS</a>
      <a href="/sitemap-index.xml">Sitemap</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 0;
    margin-top: 3rem;
    background: var(--color-surface);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-copy {
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .footer-nav {
    display: flex;
    gap: 1.25rem;
  }

  .footer-nav a {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .footer-nav a:hover {
    color: var(--color-accent);
  }
</style>
