---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AuthorBio from '../components/AuthorBio.astro';

export interface Props {
  title: string;
  description: string;
  date: string;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags = [] } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="container">
    <article class="post">
      <header class="post-header">
        <div class="tags">
          {tags.map((tag) => <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`} class="tag">{tag}</a>)}
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <time class="post-date" datetime={date}>{formattedDate}</time>
      </header>

      <div class="post-content prose">
        <slot />
      </div>

      <AuthorBio />

      <aside class="affiliate-notice">
        <strong>Disclosure:</strong> This page contains affiliate links. If you purchase through our links, we may earn a commission at no extra cost to you. See our <a href="/disclaimer">full disclaimer</a>.
      </aside>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .post {
    padding: 2rem 0 4rem;
  }

  .post-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .tag {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.15rem 0.65rem;
    font-size: 0.8rem;
    color: var(--color-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .tag:hover {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 0.75rem;
  }

  .post-description {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
  }

  .post-date {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  /* Prose styles */
  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    line-height: 1.3;
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.4rem;
  }

  .prose :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    margin: 0 0 1.25rem;
  }

  .prose :global(ul), .prose :global(ol) {
    margin: 0 0 1.25rem 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    margin: 1.5rem 0;
    padding: 0.5rem 1rem;
    background: var(--color-surface);
    border-radius: 0 var(--radius) var(--radius) 0;
    color: var(--color-muted);
    font-style: italic;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .prose :global(th), .prose :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .prose :global(th) {
    background: var(--color-surface);
    font-weight: 600;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .affiliate-notice {
    margin-top: 3rem;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.85rem;
    color: var(--color-muted);
  }
</style>
